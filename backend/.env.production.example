# Copy this to .env on the EC2 instance (or pass these as `docker run -e`
# flags / an env file) once you have real RDS + EC2 details. Never commit
# the real .env — it's gitignored.

# --- Database (RDS) ---
# Found on the RDS instance's "Connectivity & security" tab after creation.
POSTGRES_USER=requestflow_admin
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=requestflow
POSTGRES_HOST=requestflow-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432

# RDS Postgres supports TLS out of the box; "require" enforces an encrypted
# connection without validating the CA cert chain. Local docker-compose
# Postgres has no cert, so leave this unset (defaults to "prefer") there.
POSTGRES_SSLMODE=require

# --- Auth ---
# Generate a new one for production, don't reuse the local dev value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_value

# --- CORS ---
# Comma-separated, no trailing slashes. Add your CloudFront/S3 static site
# URL and/or custom domain once you know it.
ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net,https://your-custom-domain.com
