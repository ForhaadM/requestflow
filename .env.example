POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
POSTGRES_HOST = localhost
POSTGRES_PORT = 5432
SECRET_KEY = "your_key"

# Powers the chatbot assistant (chat.py/chatbot.py) and proactive duplicate
# detection (duplicate_detection.py). Both features fail open — the app
# still runs without this set, the AI features just degrade gracefully.
ANTHROPIC_API_KEY = "your_anthropic_api_key"

# Comma-separated list of allowed frontend origins for CORS. Optional for
# local dev — defaults to the Vite dev server (localhost:5173).
# ALLOWED_ORIGINS=https://d111111abcdef8.cloudfront.net,https://requestflow.example.com